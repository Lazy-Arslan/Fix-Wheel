<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Top Section: Logo + App Name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <!-- FixWheel Logo -->
            <ImageView
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:src="@drawable/fix_wheel"
                android:contentDescription="@string/app_name"
                android:scaleType="fitCenter" />

            <!-- App Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#003D82"
                android:layout_marginTop="12dp"
                android:letterSpacing="0.05" />

            <!-- Tagline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/splash_tagline"
                android:textSize="13sp"
                android:textColor="#667799"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- Login Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_white_background"
            android:padding="28dp"
            android:elevation="8dp">

            <!-- Welcome Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome to FixWheel"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#003D82"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign in to continue"
                android:textSize="13sp"
                android:textColor="#999999"
                android:layout_marginBottom="24dp" />

            <!-- Name Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#003D82"
                android:layout_marginBottom="6dp" />

            <!-- Name Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:background="@drawable/input_background"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="18sp"
                    android:layout_marginEnd="10dp" />

                <EditText
                    android:id="@+id/loginName"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Enter your full name"
                    android:inputType="textPersonName|textCapWords"
                    android:background="@android:color/transparent"
                    android:textColor="#222222"
                    android:textColorHint="#BBBBBB"
                    android:textSize="15sp"
                    android:maxLines="1" />
            </LinearLayout>

            <!-- CNIC Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CNIC Number"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#003D82"
                android:layout_marginBottom="6dp" />

            <!-- CNIC Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:background="@drawable/input_background"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🪪"
                    android:textSize="18sp"
                    android:layout_marginEnd="10dp" />

                <EditText
                    android:id="@+id/loginPhone"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Enter your CNIC number"
                    android:inputType="number"
                    android:background="@android:color/transparent"
                    android:textColor="#222222"
                    android:textColorHint="#BBBBBB"
                    android:textSize="15sp"
                    android:maxLines="1" />
            </LinearLayout>

            <!-- Login Button -->
            <Button
                android:id="@+id/loginBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="LOGIN"
                android:textStyle="bold"
                android:textSize="16sp"
                android:letterSpacing="0.1"
                android:textColor="@android:color/white"
                android:background="@drawable/button_blue_background"
                android:layout_marginBottom="20dp" />

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E0E0E0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  OR  "
                    android:textSize="12sp"
                    android:textColor="#AAAAAA" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E0E0E0" />
            </LinearLayout>

            <!-- Register Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New User? "
                    android:textSize="14sp"
                    android:textColor="#666666" />

                <TextView
                    android:id="@+id/registerNow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Register Now"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#003D82" />
            </LinearLayout>

        </LinearLayout>

        <!-- Bottom padding -->
        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>