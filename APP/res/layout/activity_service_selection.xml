<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- SELECT VEHICLE TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Vehicle"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#003366"
            android:layout_marginBottom="12dp" />

        <!-- VEHICLE ICON CARDS (horizontal scroll) -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:id="@+id/vehicleContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- CAR -->
                <LinearLayout
                    android:id="@+id/vehicleCar"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/vehicle_card_selected"
                    android:padding="8dp"
                    android:layout_marginEnd="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚗"
                        android:textSize="30sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Car"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#003366"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- BIKE -->
                <LinearLayout
                    android:id="@+id/vehicleBike"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/vehicle_card_unselected"
                    android:padding="8dp"
                    android:layout_marginEnd="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏍️"
                        android:textSize="30sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bike"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#003366"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- E-BIKE -->
                <LinearLayout
                    android:id="@+id/vehicleEbike"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/vehicle_card_unselected"
                    android:padding="8dp"
                    android:layout_marginEnd="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛵"
                        android:textSize="30sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="E-Bike"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#003366"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- TRUCK -->
                <LinearLayout
                    android:id="@+id/vehicleTruck"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/vehicle_card_unselected"
                    android:padding="8dp"
                    android:layout_marginEnd="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚛"
                        android:textSize="30sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Truck"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#003366"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- RICKSHAW -->
                <LinearLayout
                    android:id="@+id/vehicleRickshaw"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/vehicle_card_unselected"
                    android:padding="8dp"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛺"
                        android:textSize="30sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rickshaw"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#003366"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- SELECT ISSUE TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Issue"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#003366"
            android:layout_marginBottom="8dp" />

        <!-- ISSUE SPINNER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/rounded_white_background"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔧"
                android:textSize="18sp"
                android:layout_marginEnd="10dp" />

            <Spinner
                android:id="@+id/issueSpinner"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent" />
        </LinearLayout>

        <EditText
            android:id="@+id/customIssueET"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:visibility="gone"
            android:hint="Describe your issue"
            android:background="@drawable/edittext_rounded"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <!-- ESTIMATED CHARGES CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp"
            android:background="@drawable/rounded_white_background"
            android:elevation="3dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estimated Charges"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#003366"
                android:layout_marginBottom="12dp" />

            <!-- Service + Delivery rows -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Service Charges"
                    android:textSize="13sp"
                    android:textColor="#777777" />

                <TextView
                    android:id="@+id/chargesTV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rs. 100"
                    android:textSize="13sp"
                    android:textColor="#333333" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Delivery Charges"
                    android:textSize="13sp"
                    android:textColor="#777777" />

                <TextView
                    android:id="@+id/deliveryChargesTV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rs. 50"
                    android:textSize="13sp"
                    android:textColor="#333333" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="14dp" />

            <!-- YOUR OFFER label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Offer"
                android:textSize="13sp"
                android:textColor="#777777"
                android:layout_marginBottom="10dp" />

            <!-- +/- OFFER ROW (InDrive style) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- MINUS BUTTON -->
                <Button
                    android:id="@+id/decreaseBtn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="−"
                    android:textSize="22sp"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#003D82"
                    android:padding="0dp" />

                <!-- OFFER AMOUNT -->
                <TextView
                    android:id="@+id/offerAmountTV"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Rs. 150"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#003D82" />

                <!-- PLUS BUTTON -->
                <Button
                    android:id="@+id/increaseBtn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="+"
                    android:textSize="22sp"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#003D82"
                    android:padding="0dp" />

            </LinearLayout>

            <!-- Hint text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Adjust your offer. Mechanics will respond to your price."
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- FIND MECHANICS BUTTON -->
        <Button
            android:id="@+id/searchMechanicsBtn"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="20dp"
            android:text="FIND NEAREST MECHANICS"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#003D82" />

        <!-- NEARBY MECHANICS TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nearby Mechanics"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#003366"
            android:layout_marginBottom="10dp" />

        <!-- MECHANICS RECYCLERVIEW -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/mechanicsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>

</ScrollView>