<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f5f5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="30dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:contentDescription="FixWheel"
                android:src="@drawable/fix_wheel" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mechanic Registration"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#003366"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <!-- Full Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Name *"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/mechanicName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Enter your full name"
            android:inputType="textPersonName|textCapWords"
            android:padding="12dp"
            android:background="@drawable/edittext_rounded"
            android:layout_marginBottom="15dp" />

        <!-- CNIC -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CNIC Number *"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/mechanicCnic"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Enter your CNIC number"
            android:inputType="number"
            android:padding="12dp"
            android:background="@drawable/edittext_rounded"
            android:layout_marginBottom="15dp" />

        <!-- Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email *"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/mechanicEmail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Enter your email"
            android:inputType="textEmailAddress"
            android:padding="12dp"
            android:background="@drawable/edittext_rounded"
            android:layout_marginBottom="15dp" />

        <!-- Phone -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone Number *"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/mechanicPhone"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Enter your phone number"
            android:inputType="phone"
            android:padding="12dp"
            android:background="@drawable/edittext_rounded"
            android:layout_marginBottom="15dp" />

        <!-- City -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="City *"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/mechanicCity"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Enter your city"
            android:inputType="text"
            android:padding="12dp"
            android:background="@drawable/edittext_rounded"
            android:layout_marginBottom="15dp" />

        <!-- Shop Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shop Name *"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/shopName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Enter your shop name"
            android:inputType="text"
            android:padding="12dp"
            android:background="@drawable/edittext_rounded"
            android:layout_marginBottom="15dp" />

        <!-- License Number -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="License Number *"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/licenseNumber"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Enter your license number"
            android:inputType="text"
            android:padding="12dp"
            android:background="@drawable/edittext_rounded"
            android:layout_marginBottom="15dp" />

        <!-- Specialization -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Specialization"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/specializationSpinner"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="15dp"
            android:background="@drawable/edittext_rounded"
            android:entries="@array/specialization_array" />

        <!-- Years of Experience -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Years of Experience"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/yearsExperience"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Enter years of experience"
            android:inputType="number"
            android:padding="12dp"
            android:background="@drawable/edittext_rounded"
            android:layout_marginBottom="15dp" />

        <!-- Shop Address -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shop Address"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/shopAddress"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:hint="Enter your shop address"
            android:inputType="textMultiLine"
            android:padding="12dp"
            android:background="@drawable/edittext_rounded"
            android:layout_marginBottom="25dp"
            android:gravity="top" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shop location *"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/shopLocationStatusTV"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Search or tap map to set your shop (e.g. Taxila)"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/pickShopLocationBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Set shop location on map"
            android:backgroundTint="#003D82"
            android:textColor="@android:color/white"
            android:layout_marginBottom="20dp" />

        <!-- Register Button -->
        <Button
            android:id="@+id/mechanicSubmitBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="REGISTER"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/button_rounded_secondary"
            android:textColor="@color/white"
            android:layout_marginBottom="20dp" />

    </LinearLayout>

</ScrollView>